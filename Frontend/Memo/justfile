www := "/var/www/organizator.ro"

# default target
build:
  reset
  npm run build
  cp favicon-green.ico build/main/favicon.ico

install-dependencies:
  npm update
  npm install
  npm install typescript --save-dev

deploy: build
  cp src/html/* {{www}}
  cp -r build/main/dom/ {{www}}

vite: build
  cp -r ../organizator-wasm/pkg/ build/main/
  npm run vite:build

dev:
  npm run dev

_deploy-vite: vite
  cp dist/build/main/* {{www}}
  cp -r images/ {{www}}
  cp -r dist/assets/ {{www}}

deb:
  rm -rf deb && \
  cd ../.. && \
    cd Frontend/Memo && \
    mkdir -p deb && \
    cp dist/build/main/* deb/ && \
    cp -r dist/assets/ deb/ && \
    cp -r images/ deb/ && \
    cp favicon.ico deb/ && \
    cp src/html/org-manifest.json deb/

deploy-deb:
  cp -r deb/. {{www}}

